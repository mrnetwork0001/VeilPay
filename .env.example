# ─── Blockchain ────────────────────────────────────────────────────────────────
# Sepolia RPC URL from Alchemy, Infura, or any provider
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Private key of the deployer wallet (no 0x prefix needed in some configs, but safe to include)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Etherscan API key for contract verification
ETHERSCAN_API_KEY=YOUR_ETHERSCAN_API_KEY

# ─── Frontend (Vite) ────────────────────────────────────────────────────────────
# Contract address after deployment — update this after running deploy:sepolia
VITE_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000

# Sepolia RPC for the frontend (can be the same Alchemy key)
VITE_SEPOLIA_RPC=https://eth-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_KEY

# Chain ID for Sepolia
VITE_CHAIN_ID=11155111

# IPFS via Pinata — get a free JWT at https://app.pinata.cloud/developers/api-keys
# Leave empty to use demo mode for resume uploads
VITE_PINATA_JWT=your_pinata_jwt_here
